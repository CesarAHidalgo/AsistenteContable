generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  CASH
  NEQUI
  DAVIPLATA
  OTHER
}

enum DebtType {
  FIXED_INSTALLMENT
  REVOLVING_CREDIT
  CREDIT_CARD
}

enum ReminderType {
  PAYMENT
  ALARM
}

enum ReminderDeliveryChannel {
  EMAIL
  PUSH
  WHATSAPP
}

enum ReminderDeliveryStatus {
  SENT
  SKIPPED
  FAILED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String?
  googleId     String?       @unique
  billingCycleStartDay Int   @default(1)
  billingCycleEndDay Int     @default(31)
  billingCycleReferenceStart DateTime?
  billingCycleReferenceEnd DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]
  apiTokens    ApiToken[]
  transactions Transaction[]
  debts        Debt[]
  reminders    Reminder[]
  pushSubscriptions PushSubscription[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiToken {
  id         String    @id @default(cuid())
  name       String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            String          @id @default(cuid())
  description   String
  amount        Decimal         @db.Decimal(12, 2)
  type          TransactionType
  category      String
  paymentMethod PaymentMethod
  installmentCount Int?
  transactionAt DateTime
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Debt {
  id             String        @id @default(cuid())
  name           String
  type           DebtType      @default(FIXED_INSTALLMENT)
  initialAmount  Decimal       @db.Decimal(12, 2)
  currentAmount  Decimal       @db.Decimal(12, 2)
  installmentCount Int?
  startedAt      DateTime?
  annualEffectiveRate Decimal? @db.Decimal(8, 4)
  monthlyPayment Decimal?      @db.Decimal(12, 2)
  creditLimit    Decimal?      @db.Decimal(12, 2)
  minimumPaymentAmount Decimal? @db.Decimal(12, 2)
  dueDayOfMonth  Int?
  statementDayOfMonth Int?
  statementDayPurchasesToNextCycle Boolean @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  payments       DebtPayment[]
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DebtPayment {
  id        String   @id @default(cuid())
  amount    Decimal  @db.Decimal(12, 2)
  principalAmount Decimal @default(0) @db.Decimal(12, 2)
  interestAmount Decimal  @default(0) @db.Decimal(12, 2)
  paidAt    DateTime
  createdAt DateTime @default(now())
  debtId    String
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
}

model Reminder {
  id               String   @id @default(cuid())
  title            String
  type             ReminderType @default(PAYMENT)
  amount           Decimal? @db.Decimal(12, 2)
  dueDate          DateTime
  notificationAt   DateTime?
  notifyDaysBefore Int      @default(5)
  notifyEmail      Boolean  @default(true)
  notifyPush       Boolean  @default(false)
  notifyWhatsApp   Boolean  @default(false)
  isCompleted      Boolean  @default(false)
  completedAt      DateTime?
  paymentRecordedAt DateTime?
  lastNotifiedAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries       ReminderDelivery[]
}

model ReminderDelivery {
  id          String                 @id @default(cuid())
  channel     ReminderDeliveryChannel
  status      ReminderDeliveryStatus
  scheduledFor DateTime
  sentAt      DateTime?
  message     String?
  errorMessage String?
  createdAt   DateTime               @default(now())
  reminderId  String
  reminder    Reminder               @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId, scheduledFor])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dhKey String
  authKey   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
