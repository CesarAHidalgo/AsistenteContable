{
  "name": "asistente-contable",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/select-prisma-runtime.mjs && next build",
    "start": "next start",
    "cf:prepare-wasm": "node scripts/prepare-cloudflare-wasm.mjs",
    "preview": "cross-env PRISMA_RUNTIME_TARGET=cloudflare opennextjs-cloudflare build && npm run cf:prepare-wasm && opennextjs-cloudflare preview",
    "deploy": "cross-env PRISMA_RUNTIME_TARGET=cloudflare opennextjs-cloudflare build && npm run cf:prepare-wasm && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint .",
    "db:push": "prisma db push && node scripts/select-prisma-runtime.mjs",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate && node scripts/select-prisma-runtime.mjs"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.6.4",
    "@prisma/adapter-neon": "^6.19.2",
    "@prisma/adapter-pg": "^6.5.0",
    "@prisma/client": "^6.5.0",
    "next": "^15.2.4",
    "next-auth": "^4.24.13",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.17",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "prisma": "^6.5.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.25.0"
  }
}
